alternate-normal-foreground: #88B8F8;
alternate-urgent-background: #010103;
alternate-urgent-foreground: #88B8F8;

selected-active-background: #168184;
selected-active-foreground: #010103;
selected-normal-background: #168184;
selected-normal-foreground: #010103;
