 /* wallust template - colors-rofi */

* {
active-background: #168184;
active-foreground: #88B8F8;
normal-background: #010103;
normal-foreground: #88B8F8;
urgent-background: #9D271F;
urgent-foreground: #88B8F8;

alternate-active-background: #1A6B8C;
alternate-active-foreground: #88B8F8;
